{
  "name": "custombrowser",
  "version": "1.0.0",
  "description": "Custom Browser Built with Electron",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder --publish never"
  },
  "keywords": [],
  "author": "Z1per-36 <z1per@example.com>",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "cross-fetch": "^4.1.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unzip-crx-3": "^0.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jimp": "^1.6.1",
    "sharp": "^0.35.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.custombrowser.app",
    "productName": "CustomBrowser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "browserview-preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github"
    }
  }
}
